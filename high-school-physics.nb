Cell["\<\
Manipulate[
 Module[{s, x0 = 1, slope},
  s[t_] := t^2;
  slope = (s[x0 + dt] - s[x0])/dt;
  Plot[s[t], {t, 0, 3}, PlotRange -> {{0, 3}, {0, 9}},
   Epilog -> {Red, Thick, Line[{{x0, s[x0]}, {x0 + dt, s[x0 + dt]}}],
     Blue, PointSize[0.02], Point[{x0, s[x0]}], Point[{x0 + dt, s[x0 + \
dt]}]},
   AxesLabel -> {\"t\", \"s\"}, ImageSize -> 430,
   PlotLabel -> Row[{\"\[ARing]\.b9\.b3\[ARing]\.9d\.87\[EAcute]\.80\.9f\
\[ARing]\.ba\.a6 \[CapitalDelta]s/\[CapitalDelta]t = \", NumberForm[N[slope], \
4]}]]],
 {{dt, 1.5, \"\[CapitalDelta]t\"}, 0.05, 2, 0.01}]\
\>", "Input",ExpressionUUID->"dc2dec4b-9f18-4419-8ffe-44efc19b0d6e"],

